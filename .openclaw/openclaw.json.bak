{
  "logging": {
    "level": "info",
    "file": "/home/wicma/wicclaw/.openclaw/openclaw.log"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-5"
      },
      "models": {
        "anthropic/claude-sonnet-4-5": {}
      },
      "workspace": "/home/wicma/wicclaw",
      "heartbeat": {
        "every": "0m"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "streaming": "partial"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "custom",
    "customBindHost": "127.0.0.1",
    "auth": {
      "mode": "token",
      "token": "${MASTER_API_TOKEN}"
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.3.24",
    "lastTouchedAt": "2026-03-27T22:02:22.290Z"
  }
}
